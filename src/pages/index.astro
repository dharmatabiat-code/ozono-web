<section id="contacto" class="py-16 md:py-24 bg-white relative overflow-hidden">
  <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-8 md:gap-12 lg:gap-16 items-center">
    
    <!-- INFO -->
