        </select>

        <button id="btn-contacto" type="submit" class="w-full bg-linear-to-r from-teal-600 to-teal-700 text-white py-4 rounded-2xl font-bold hover:scale-[1.02] hover:shadow-xl transition-all duration-300 flex items-center justify-center gap-2">
          <i class="fab fa-whatsapp"></i>
