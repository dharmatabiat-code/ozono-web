        </div>

        <!-- Teléfono -->
        <div class="flex items-center gap-4">
          <div class="w-12 h-12 bg-teal-50 text-teal-600 rounded-2xl flex items-center justify-center shadow-sm">
            <i class="fab fa-whatsapp text-lg"></i>
          </div>
          <p class="text-slate-700 font-medium">+51 997 307 782</p>
        </div>
      </div>
    </div>

    <!-- FORM -->
    <form id="form-contacto" class="animate-on-scroll animate-fade-right bg-slate-50 p-6 md:p-8 lg:p-10 rounded-4xl md:rounded-[2.5rem] shadow-xl border border-slate-100 hover:shadow-2xl transition-all duration-500">
      <div class="grid gap-6">
        <input type="text" id="input-nombre" placeholder="Tu nombre completo" class="p-4 bg-white border border-slate-200 rounded-2xl focus:ring-4 focus:ring-teal-100 focus:border-teal-400 outline-none transition-all" required />

        <input type="tel" id="input-telefono" placeholder="WhatsApp / Teléfono" class="p-4 bg-white border border-slate-200 rounded-2xl focus:ring-4 focus:ring-teal-100 focus:border-teal-400 outline-none transition-all" required />

        <select id="input-motivo" class="p-4 bg-white border border-slate-200 rounded-2xl focus:ring-4 focus:ring-teal-100 focus:border-teal-400 outline-none text-slate-500" required>
