---
import Layout_legal from "../../layouts/Layout_legal.astro";
import { company } from "../../data/company";

const sections = [
  { id: "responsable", title: "1. Responsable del Tratamiento", icon: "fa-user-tie" },
  { id: "datos", title: "2. Datos que Recogemos", icon: "fa-database" },
  { id: "finalidad", title: "3. Finalidad del Tratamiento", icon: "fa-bullseye" },
  { id: "comparticion", title: "4. Compartición de Datos", icon: "fa-share-nodes" },
  { id: "derechos", title: "5. Derechos ARCO", icon: "fa-shield-halved" },
  { id: "seguridad", title: "6. Seguridad de la Información", icon: "fa-lock" },
  { id: "contacto", title: "7. Soporte de Privacidad", icon: "fa-user-shield" },
];

const lastUpdated = "10/04/2026";
const location = "Ayacucho, Perú";
---

<Layout_legal
  title="Política de Privacidad - Ozono Clinic"
  description="Conozca cómo protegemos y gestionamos sus datos personales en Ozono Clinic y Dharma."
>
  <!-- Hero Section -->
  <section class="relative bg-slate-50 py-24 pt-32 overflow-hidden">
    <div class="absolute inset-0 z-0 pointer-events-none">
      <img 
        src="/img/legales/privacy-bg.png" 
        alt="Background" 
        class="w-full h-full object-cover opacity-20 filter grayscale"
      />
      <div class="absolute inset-0 bg-linear-to-br from-slate-50/90 via-white/80 to-teal-50/90"></div>
      <div class="absolute inset-x-0 bottom-0 h-32 bg-linear-to-t from-white to-transparent"></div>
    </div>

    <div class="relative z-10 max-w-4xl mx-auto px-5 text-center">
      <h1 class="text-5xl md:text-6xl font-serif text-slate-900 mb-6" data-aos="fade-up">
        Política de <span class="text-teal-600">Privacidad</span>
      </h1>
      <p class="text-slate-500 max-w-2xl mx-auto font-light leading-relaxed text-lg" data-aos="fade-up" data-aos-delay="200">
        En Ozono Clinic, la confidencialidad de su historial médico y datos personales es nuestra prioridad bajo los estándares éticos de Dharma.
      </p>
      <p class="text-slate-400 max-w-2xl mx-auto font-medium tracking-widest uppercase text-[10px] pt-10" data-aos="fade-up">
        Última actualización: {lastUpdated} — {location}
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-5">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-16">
        
        <!-- Sidebar Navigation -->
        <aside class="hidden lg:block lg:col-span-4 sticky top-32 h-fit">
          <div class="border-l-2 border-teal-100 pl-6 space-y-5">
            <p class="text-[10px] uppercase tracking-[0.3em] text-slate-400 font-bold mb-6">Contenido</p>
            {sections.map((sec) => (
              <a href={`#${sec.id}`} class="nav-link block text-sm text-slate-500 hover:text-teal-600 transition-all hover:translate-x-2 font-medium">
                {sec.title}
              </a>
            ))}
          </div>
        </aside>

        <!-- Main Content -->
        <div class="lg:col-span-8">
          <nav class="flex items-center gap-2 text-sm text-gray-500 mb-8">
            <a href="/" class="hover:text-teal-600 transition-colors">Inicio</a>
            <span class="text-gray-300">/</span>
            <span class="text-gray-700 font-medium">Política de Privacidad</span>
          </nav>
          
          <!-- 01 Responsable -->
          <article id="responsable" class="mb-20 scroll-mt-32" data-aos="fade-up">
            <div class="flex items-center gap-4 mb-6">
                  <h2 class="text-2xl font-bold text-slate-800 mb-6 flex items-center gap-4">
              <span class="text-teal-500 font-serif opacity-30 text-4xl">01</span> 
               Responsable del Tratamiento</h2>
            </div>
            <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100">
                <p class="text-slate-700 font-bold mb-3">Ozono Clinic (Grupo Dharma)</p>
                <ul class="space-y-3 text-slate-600 text-sm">
                    <li class="flex items-center gap-3"><i class="fas fa-map-marker-alt text-teal-500 w-4"></i> {company.address.street}, {company.address.city}</li>
                    <li class="flex items-center gap-3"><i class="fas fa-envelope text-teal-500 w-4"></i> {company.contact.email}</li>
                    <li class="flex items-center gap-3"><i class="fas fa-phone text-teal-500 w-4"></i> {company.contact.phone}</li>
                </ul>
            </div>
          </article>

          <!-- 02 Datos -->
          <article id="datos" class="mb-20 scroll-mt-32" data-aos="fade-up">
            <h2 class="text-2xl font-bold text-slate-800 mb-6 flex items-center gap-4">
                <span class="text-teal-500 font-serif opacity-30 text-4xl">02</span> 
                Datos que Recogemos
            </h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                {[
                  { t: "Identificación", d: "Nombre, apellidos y DNI para registro médico legal." },
                  { t: "Contacto", d: "Teléfono de WhatsApp y correo electrónico para seguimiento." },
                  { t: "Salud", d: "Historial médico, alergias y antecedentes para tratamientos seguros." },
                  { t: "Navegación", d: "IP y cookies técnicas para mejorar la seguridad del sitio." }
                ].map((item) => (
                    <div class="p-5 border border-slate-100 rounded-2xl hover:border-teal-200 hover:bg-teal-50/30 transition-all group">
                        <p class="font-bold text-slate-800 text-sm mb-1 group-hover:text-teal-700">{item.t}</p>
                        <p class="text-slate-500 text-xs leading-relaxed">{item.d}</p>
                    </div>
                ))}
            </div>
          </article>

          <!-- 03 Finalidad -->
          <article id="finalidad" class="mb-20 scroll-mt-32" data-aos="fade-up">
            <h2 class="text-2xl font-bold text-slate-800 mb-6 flex items-center gap-4">
              <span class="text-teal-500 font-serif opacity-30 text-4xl">03</span> 
               Finalidad del Tratamiento</h2>
            <p class="text-slate-600 leading-relaxed mb-6">Sus datos son tratados bajo el principio de licitud con el fin de:</p>
            <ul class="grid grid-cols-1 gap-3">
                {[
                  "Gestionar citas y responder consultas médicas especializadas.",
                  "Enviar recordatorios de tratamiento y protocolos post-operatorios.",
                  "Informar sobre avances en medicina regenerativa y ozonoterapia.",
                  "Dar cumplimiento a la Ley N° 29733 de Protección de Datos Personales."
                ].map((text) => (
                    <li class="flex items-start gap-3 text-slate-600 text-sm bg-slate-50 p-4 rounded-xl">
                        <i class="fas fa-check-circle text-teal-500 mt-1"></i>
                        <span>{text}</span>
                    </li>
                ))}
            </ul>
          </article>

          <!-- 04 Compartición (Nueva) -->
          <article id="comparticion" class="mb-20 scroll-mt-32" data-aos="fade-up">
            <h2 class="text-2xl font-bold text-slate-800 mb-6 flex items-center gap-4">
                <span class="text-teal-500 font-serif opacity-30 text-4xl">04</span> 
                Compartición de Datos
            </h2>
            <p class="text-slate-600 text-sm leading-relaxed border-l-4 border-teal-500 pl-4">
                No vendemos ni cedemos sus datos a terceros. Solo se comparten con laboratorios asociados o entidades gubernamentales por estricto requerimiento legal o médico.
            </p>
          </article>

          <!-- 05 Derechos ARCO -->
          <article id="derechos" class="mb-20 scroll-mt-32" data-aos="fade-up">
            <h2 class="text-2xl font-bold text-slate-800 mb-6 flex items-center gap-4">
                <span class="text-teal-500 font-serif opacity-30 text-4xl">05</span> 
                Derechos ARCO
            </h2>
            <p class="text-slate-600 leading-relaxed mb-6">Usted tiene el control total sobre su información.</p>
            <div class="bg-slate-900 text-white p-8 rounded-4xl shadow-xl relative overflow-hidden">
                <div class="relative z-10">
                  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
                    {['Acceso', 'Rectificación', 'Cancelación', 'Oposición'].map(d => (
                      <div class="text-center p-2 border border-white/10 rounded-lg text-[10px] uppercase tracking-tighter bg-white/5">{d}</div>
                    ))}
                  </div>
                  <p class="text-sm opacity-90 mb-4 font-light">Para ejercer estos derechos, envíe una solicitud firmada adjuntando copia de su DNI a:</p>
                  <a href={`mailto:${company.contact.email}`} class="text-xl font-mono text-teal-400 font-bold hover:text-teal-300 transition-colors">{company.contact.email}</a>
                </div>
                <i class="fas fa-shield-halved absolute -right-10 -bottom-10 text-9xl text-white/5"></i>
            </div>
          </article>

          <!-- 06 Seguridad (Nueva) -->
          <article id="seguridad" class="mb-20 scroll-mt-32" data-aos="fade-up">
              <h2 class="text-2xl font-bold text-slate-800 mb-6 flex items-center gap-4">
              <span class="text-teal-500 font-serif opacity-30 text-4xl">06</span> 
               Seguridad de la Información</h2>
            <p class="text-slate-600 text-sm leading-relaxed">
                Implementamos cifrado SSL de 256 bits y protocolos de acceso restringido para garantizar que su historial médico permanezca privado e inalterable.
            </p>
          </article>

          <!-- 07 Contacto -->
           <article id="contacto" class="scroll-mt-32" data-aos="fade-up">
            <div class="bg-slate-900 rounded-[3rem] p-10 md:p-16 relative overflow-hidden shadow-2xl shadow-teal-900/20">
                <div class="absolute top-0 right-0 w-96 h-96 bg-teal-500/10 rounded-full blur-[100px] translate-x-1/2 -translate-y-1/2"></div>
                
                <div class="relative z-10">
                    <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">Privacidad y <span class="text-teal-500">Confianza</span></h2>
                    <p class="text-slate-400 mb-10 text-lg font-light leading-relaxed">
                        Si tiene dudas sobre cómo manejamos su información sensible, nuestro Oficial de Protección de Datos le atenderá directamente.
                    </p>
                    
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <a href={`mailto:${company.contact.email}`} class="flex items-center gap-4 p-6 rounded-3xl bg-white/5 border border-white/10 hover:bg-white/10 hover:border-teal-500/50 transition-all duration-500 group">
                            <div class="w-12 h-12 bg-teal-500 rounded-2xl flex items-center justify-center text-slate-900 group-hover:scale-110 transition-transform">
                                <i class="fas fa-shield-alt"></i>
                            </div>
                            <div class="flex flex-col">
                                <span class="text-[10px] text-teal-500 font-bold uppercase tracking-widest">Protección de Datos</span>
                                <span class="text-white text-sm">{company.contact.email}</span>
                            </div>
                        </a>
                        <div class="flex items-center gap-4 p-6 rounded-3xl bg-white/5 border border-white/10">
                            <div class="w-12 h-12 bg-white/10 rounded-2xl flex items-center justify-center text-white">
                                <i class="fas fa-check"></i>
                            </div>
                            <div class="flex flex-col">
                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">Estado</span>
                                <span class="text-white text-sm">Cumplimiento Ley 29733</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
          </article>

          <!-- Back Button -->
          <div class="mt-16 flex justify-center">
            <a href="/" class="group flex items-center gap-3 text-slate-400 hover:text-teal-600 transition-all font-bold text-xs uppercase tracking-widest">
                <i class="fas fa-arrow-left group-hover:-translate-x-1 transition-transform"></i>
                Volver a Inicio
            </a>
          </div>

        </div>
      </div>
    </div>
  </section>
</Layout_legal>

<style>
  html { scroll-behavior: smooth; }
  .nav-link { position: relative; transition: all 0.3s ease; }
  .nav-link::before {
    content: ''; position: absolute; left: -26px; top: 50%;
    width: 0; height: 2px; background-color: #0d9488;
    transition: width 0.3s ease;
  }
  .nav-link:hover::before { width: 15px; }
</style>