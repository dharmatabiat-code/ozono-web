---
// TestimonialsSection.astro
import { testimonials } from "../../data/testimonials";
const { ...props } = Astro.props;
---

<section id="testimonios" class="py-16 md:py-32 bg-slate-50 relative overflow-hidden" {...props}>
  <div class="absolute -top-24 -right-24 w-96 h-96 bg-[#338B85]/5 rounded-full blur-3xl"></div>
  
  <div class="max-w-350 mx-auto px-6 relative z-10">
    
    <div class="flex flex-col md:flex-row items-center md:items-end justify-between mb-12 md:mb-20 gap-8" data-aos="fade-right">
      <div class="text-center md:text-left">
        <div class="flex items-center justify-center md:justify-start gap-3 mb-4">
          <span class="w-10 h-1 bg-linear-to-r from-[#338B85] to-teal-200 rounded-full"></span>
          <span class="text-[#338B85] font-bold uppercase tracking-[0.2em] text-[10px] md:text-xs">Historias de Éxito</span>
        </div>
        <h2 class="text-3xl md:text-5xl font-black text-slate-900 leading-tight">
          Confianza que <span class="text-[#338B85]">Sana</span>
        </h2>
      </div>
      
      <div class="flex items-center gap-4 bg-white px-5 py-2.5 rounded-2xl shadow-sm border border-slate-100" data-aos="zoom-in" data-aos-delay="300">
        <div class="flex text-amber-400 text-xs md:text-sm">
          <i class="fas fa-star"></i>
          <i class="fas fa-star"></i>
          <i class="fas fa-star"></i>
          <i class="fas fa-star"></i>
          <i class="fas fa-star"></i>
        </div>
        <span class="font-bold text-slate-700 text-sm">4.9/5</span>
      </div>
    </div>

    <div class="relative max-w-4xl mx-auto">
      <div class="overflow-hidden touch-pan-y">
        <div class="testimonial-slider flex items-stretch transition-transform duration-700 ease-[cubic-bezier(0.45,0,0.55,1)]">
          {testimonials.map((item, index) => (
            <div class="w-full shrink-0 px-2 md:px-4" 
                 data-aos="fade-up" 
                 data-aos-delay={index * 150}
                 data-aos-duration="1000">
              <div class="bg-white h-full p-6 md:p-12 rounded-[2.5rem] md:rounded-[3.5rem] border border-slate-100 shadow-sm relative group flex flex-col justify-between hover:shadow-xl hover:shadow-[#338B85]/5 transition-all duration-500">
                
                <i class="fa-solid fa-quote-right text-[#338B85]/10 text-6xl md:text-8xl absolute top-6 right-8 md:top-8 md:right-12 group-hover:text-[#338B85]/20 transition-colors duration-500"></i>

                <div class="relative z-10 flex flex-col h-full">
                  <div class="flex gap-1 text-amber-400 mb-6 justify-center md:justify-start">
                    {[...Array(5)].map(() => <i class="fas fa-star text-[10px] md:text-xs"></i>)}
                  </div>

                  <p class="text-slate-600 italic text-base md:text-xl leading-relaxed mb-8 text-center md:text-left grow">
                    "{item.comment}"
                  </p>

                  <div class="flex flex-col md:flex-row items-center gap-4 pt-6 md:pt-8 border-t border-slate-50">
                    <div class="relative">
                      {item.image ? (
                        <img src={item.image} alt={item.name} class="w-12 h-12 md:w-16 md:h-16 rounded-full object-cover border-2 border-white shadow-md group-hover:scale-105 transition-transform" />
                      ) : (
                        <div class="w-12 h-12 md:w-16 md:h-16 rounded-full bg-linear-to-br from-[#338B85] to-[#266964] flex items-center justify-center text-white font-bold text-lg md:text-2xl shadow-md group-hover:scale-105 transition-transform">
                          {item.name.charAt(0)}
                        </div>
                      )}
                      <div class="absolute -bottom-1 -right-1 w-5 h-5 bg-white rounded-full flex items-center justify-center shadow-sm">
                        <i class="fa-solid fa-circle-check text-[#338B85] text-[10px]"></i>
                      </div>
                    </div>
                    
                    <div class="text-center md:text-left">
                      <h4 class="font-black text-slate-900 text-base md:text-lg leading-tight">{item.name}</h4>
                      <div class="flex items-center justify-center md:justify-start gap-2 mt-1">
                        <span class="text-[10px] md:text-[11px] font-bold text-[#338B85] uppercase tracking-wider bg-[#338B85]/5 px-2 py-0.5 rounded-md">
                          {item.treatment}
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <div class="flex justify-center items-center gap-3 mt-12" data-aos="zoom-in" data-aos-offset="50">
        {testimonials.map((_, index) => (
          <button 
            class="testimonial-dot group relative h-4 flex items-center focus:outline-none"
            aria-label={`Ver testimonio ${index + 1}`}
          >
            <span class="block w-2.5 h-2.5 rounded-full bg-slate-300 transition-all duration-500 group-[.active]:bg-[#338B85] group-[.active]:w-10 group-[.active]:shadow-lg group-[.active]:shadow-[#338B85]/20"></span>
          </button>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  /* El JS de tu archivo externo manejará la clase .active */
  .testimonial-slider {
    will-change: transform;
    cursor: grab;
  }
  
  .testimonial-slider:active {
    cursor: grabbing;
  }

  /* Mejora para el desplazamiento en móviles */
  @media (max-width: 768px) {
    .testimonial-slider {
      transition-duration: 500ms; /* Un poco más rápido en móvil */
    }
  }
</style>

<script>
  import "../../scripts/testimonial-slider";
</script>