---
import { services } from "../../data/services";
const { ...props } = Astro.props;
---

<section id="servicios" class="relative py-20 lg:py-32 bg-white overflow-hidden" {...props}>
  <div class="max-w-350 mx-auto px-6">
    
    <div class="flex flex-col md:flex-row md:justify-between md:items-end mb-16 gap-8">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-5">
          <span class="w-10 h-1 bg-linear-to-r from-[#338B85] to-teal-200 rounded-full"></span>
          <span class="text-[#338B85] font-bold uppercase tracking-[0.2em] text-xs">
            Soluciones de Vanguardia
          </span>
        </div>

        <h3 class="text-3xl md:text-5xl font-black tracking-tight leading-tight text-slate-900" data-aos="fade-up" data-aos-delay="100">
          Soluciones <span class="text-[#338B85]">Médicas</span> Integrativas
        </h3>

        <p class="mt-6 text-slate-500 text-lg leading-relaxed" data-aos="fade-up" data-aos-delay="200">
          Bajo la dirección de la Dra. Amalia Luque, aplicamos protocolos internacionales 
          para tratar la raíz biológica de tu salud.
        </p>
      </div>

      <a href="#contacto" class="hidden md:flex items-center gap-2 font-bold text-[#338B85] hover:text-teal-700 transition-all group border-b-2 border-transparent hover:border-[#338B85] pb-1">
        Agendar una evaluación
        <i class="fa-solid fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
      </a>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
      {
        services.map((service, index) => (
          <div class="group relative flex flex-col p-8 lg:p-10 rounded-[2.5rem] bg-slate-50 border border-slate-100 transition-all duration-500 hover:bg-white hover:shadow-[0_30px_70px_rgba(51,139,133,0.12)] hover:-translate-y-2" data-aos="zoom-in" data-aos-delay={100 + index * 100}>
            
            <div class="w-14 h-14 lg:w-16 lg:h-16 bg-white text-[#338B85] rounded-2xl flex items-center justify-center text-2xl lg:text-3xl mb-8 group-hover:bg-[#338B85] group-hover:text-white transition-all duration-500 shadow-sm border border-slate-100">
              <i class={service.icon}></i>
            </div>

            <h4 class="text-xl lg:text-2xl font-bold text-slate-900 mb-4 group-hover:text-[#338B85] transition-colors leading-tight">
              {service.title}
            </h4>

            <p class="text-slate-500 text-sm leading-relaxed mb-8">
              {service.description}
            </p>

            <div class="space-y-3 mb-8 grow">
              {service.features.map((feature) => (
                <div class="flex items-center gap-3 text-[13px] text-slate-600 font-medium">
                  <div class="w-1.5 h-1.5 rounded-full bg-[#338B85]"></div>
                  {feature}
                </div>
              ))}
            </div>
            
            <div class="pt-6 mt-4 border-t border-slate-100 flex items-center justify-between">
               <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest italic">
                 {service.origin}
               </span>
               <i class="fa-solid fa-award text-[#338B85]/30 text-lg"></i>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>