  <style>
    /* Keyframes existentes con tiempos definidos */
    @keyframes fadeInLeft {
      from { opacity: 0; transform: translateX(-30px); }
      to { opacity: 1; transform: translateX(0); }
    }
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(30px); }
      to { opacity: 1; transform: translateY(0); }
    }
    @keyframes scaleUpFade {
      from { opacity: 0; transform: scale(0.95) translateY(20px); }
      to { opacity: 1; transform: scale(1) translateY(0); }
    }
    @keyframes floatPulse {
      0%, 100% { transform: translateY(0px) scale(1); opacity: 0.25; }
      50% { transform: translateY(-10px) scale(1.05); opacity: 0.35; }
    }

    /* Clases de utilidad para las animaciones */
    @media (min-width: 1024px) {
      .lg\:animate-fadeInLeft { animation: fadeInLeft 0.8s ease-out forwards; }
      .lg\:animate-fadeUp { animation: fadeUp 0.8s ease-out forwards; }
      .lg\:animate-scaleUpFade { animation: scaleUpFade 0.8s ease-out forwards; }
      .lg\:animate-floatPulse { animation: floatPulse 4s ease-in-out infinite; }
      
      /* Evita que los elementos parpadeen antes de la animación */
      [class*="lg:animate-"] {
        opacity: 0;
      }
    }
  </style>
