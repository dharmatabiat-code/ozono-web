---
import { company } from "../../../data/company";

interface Props {
  navItemsMobile: { label: string; href: string; class?: string }[];
  socialLinks: { icon: string; url: string }[];
}

const { navItemsMobile, socialLinks } = Astro.props;
---

<div
  id="mobile-menu"
  class="fixed inset-0 z-60 bg-slate-900/40 backdrop-blur-md opacity-0 invisible transition-all duration-500 lg:hidden"
>
  <div
    id="mobile-menu-sidebar"
    class="absolute top-0 right-0 h-full w-[85%] max-w-sm bg-white shadow-[-20px_0_60px_rgba(0,0,0,0.1)] translate-x-full transition-transform duration-700 p-10 flex flex-col"
  >
    <div class="flex justify-between items-center mb-16">
      <img src="/img/head/ozono.png" class="h-10 w-auto" alt="Osono Clinic" />
      <button id="mobile-menu-close" class="text-slate-900 p-2 hover:rotate-90 transition-transform">
        <i class="fas fa-times text-2xl font-light"></i>
      </button>
    </div>

    <nav class="flex flex-col gap-8 flex-1 overflow-auto">
      {navItemsMobile.map((item) => (
        <a
          href={item.href}
          class={`mobile-nav-link text-[14px] tracking-widest text-slate-900 hover:text-[#338B85] transition-all flex items-center justify-between group ${ item.class || '' }`}
        >
          {item.label}
          <i class="fas fa-chevron-right text-xs opacity-20 group-hover:opacity-100 group-hover:translate-x-2 transition-all" />
        </a>
      ))}
      
      <div class="mt-12 pt-10 border-t justify-center border-slate-100 space-y-10">
        <div class="space-y-4">
          <div class="space-y-4 justify-center">
           <p class="text-slate-400 text-[10px] tracking-[0.2em] uppercase font-bold text-center">
              Huamanga - Ayacucho, Perú
            </p>
          </div>
          {company.contact.linkWhatsapp && (
            <a
              href={company.contact.linkWhatsapp}
              class="w-full bg-[#338B85] text-white font-bold py-5 rounded-2xl flex items-center justify-center gap-3 text-sm shadow-xl shadow-teal-500/20"
            >
              <i class="fab fa-whatsapp text-lg"></i>
              WHATSAPP DIRECTO
            </a>
          )}
        </div>
     
        <div class="space-y-4 justify-center">
           <p class="text-slate-400 text-[10px] tracking-[0.2em] uppercase font-bold text-center">
            Síguenos en redes</p>
          </p>
          <div class="flex justify-center gap-4">
            {socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                class="w-12 h-12 bg-slate-50 border border-slate-100 rounded-2xl flex items-center justify-center text-slate-400 hover:text-[#338B85] hover:border-[#338B85] transition-all"
              >
                <i class={`fab fa-${social.icon} text-lg`} />
              </a>
            ))}
          </div>
        </div>
      </div>
    </nav>
  </div>
</div>