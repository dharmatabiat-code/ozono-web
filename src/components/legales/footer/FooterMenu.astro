---
interface Props {
  title?: string; // Hacemos el título opcional o obligatorio según prefieras
  menuItems: { label: string; href: string }[];
}

const { title = "Enlaces Rápidos", menuItems } = Astro.props;
---

<div class="flex flex-col items-center md:items-start">
  <h2 class="text-white font-bold mb-10 text-[12px] uppercase tracking-[0.4em] flex items-center gap-3">
    <span class="w-1.5 h-1.5 bg-teal-500 rounded-full shadow-[0_0_8px_rgba(20,184,166,0.6)]"></span> 
    {title}
  </h2>
  
  <nav role="navigation" aria-label="Navegación del footer">
    <ul class="space-y-5">
      {menuItems.map((item) => (
        <li>
          <a
            href={item.href}
            class="text-slate-400 hover:text-teal-400 transition-all duration-300 text-[10px] font-bold tracking-widest uppercase flex items-center group"
          >
            <span class="h-px w-0 bg-teal-500 group-hover:w-4 mr-0 group-hover:mr-3 transition-all duration-300"></span>
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</div>