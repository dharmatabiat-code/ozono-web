---
interface Props {
  socialLinks: { icon: string; url: string }[];
  whatsappUrl?: string; // La hacemos opcional con '?' para evitar errores si no hay link
}

const { socialLinks, whatsappUrl } = Astro.props;
---

<div class="flex flex-col items-center md:items-start">
  <h2 class="text-white font-bold mb-10 text-[12px] uppercase tracking-[0.4em] flex items-center gap-3">
    <span class="w-1.5 h-1.5 bg-teal-500 rounded-full shadow-[0_0_8px_rgba(20,184,166,0.6)]"></span> 
    Redes
  </h2>

  <div class="flex gap-4 mb-10">
    {socialLinks.filter(social => social.url).map((social) => (
      <a
        href={social.url}
        target="_blank"
        rel="noopener noreferrer"
        class="w-10 h-10 bg-slate-800 border border-slate-700 rounded-xl flex items-center justify-center text-slate-400 transition-all duration-500 hover:bg-slate-700 hover:border-teal-500 hover:text-teal-400 hover:-translate-y-1 hover:shadow-lg hover:shadow-teal-500/20"
        aria-label={`Visitar red social`}
      >
        <i class={`fab ${social.icon} text-sm`}></i>
      </a>
    ))}
  </div>

  <a
    href="#contacto"
    class="group relative overflow-hidden bg-teal-600 text-white font-bold px-8 py-4 rounded-2xl text-[11px] tracking-[0.2em] transition-all hover:shadow-2xl hover:shadow-teal-500/30 active:scale-95 w-full text-center"
  >
    <span class="relative z-10 uppercase flex items-center justify-center gap-2">
       <i class="fas fa-calendar-alt text-[10px]"></i> Solicitar Cita
    </span>
    <div class="absolute inset-0 bg-slate-950 translate-y-full group-hover:translate-y-0 transition-transform duration-500 ease-out"></div>
  </a>
</div>