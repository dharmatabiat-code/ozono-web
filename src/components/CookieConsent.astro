---
// Cookie Consent Banner Component
// This component handles cookie consent (analytics to be added later)
---

<div id="cookie-consent-banner" style="display: none; position: fixed; bottom: 0; left: 0; right: 0; z-index: 9999;">
  <div style="background-color: #0f172a; color: white; padding: 16px 24px; box-shadow: 0 4px 20px rgba(0,0,0,0.3);">
    <div style="max-width: 1280px; margin: 0 auto; display: flex; flex-direction: column; gap: 16px; align-items: center; justify-content: space-between;">
      <div style="flex: 1;">
        <h3 style="font-weight: bold; font-size: 18px; margin-bottom: 8px;">🍪 Uso de Cookies</h3>
        <p style="font-size: 14px; color: #cbd5e1;">
          Utilizamos cookies para mejorar tu experiencia en nuestro sitio. 
          Al continuar navegando, aceptas nuestro uso de cookies.
          <a href="/legales/politica-privacidad" style="color: #2dd4bf; text-decoration: underline;">Leer Política de Privacidad</a>
        </p>
      </div>
      <div style="display: flex; gap: 12px; flex-shrink: 0;">
        <button 
          id="cookie-reject" 
          style="padding: 10px 20px; border-radius: 9999px; border: 1px solid #475569; background: transparent; color: white; cursor: pointer; font-size: 14px; font-weight: 600;"
        >
          Rechazar
        </button>
        <button 
          id="cookie-accept" 
          style="padding: 10px 20px; border-radius: 9999px; border: none; background-color: #0d9488; color: white; cursor: pointer; font-size: 14px; font-weight: 600;"
        >
          Aceptar
        </button>
      </div>
    </div>
  </div>
</div>

<script is:inline>
  (function() {
    var banner = document.getElementById('cookie-consent-banner');
    var acceptBtn = document.getElementById('cookie-accept');
    var rejectBtn = document.getElementById('cookie-reject');
    
    // If elements don't exist, exit
    if (!banner || !acceptBtn || !rejectBtn) {
      console.log('Cookie banner elements not found');
      return;
    }
    
    // Check if user has already made a choice
    var cookieConsent = localStorage.getItem('cookieConsent');
    
    if (!cookieConsent) {
      // Show banner if no choice made
      banner.style.display = 'block';
      console.log('Showing cookie banner');
    } else {
      console.log('Cookie choice already made:', cookieConsent);
    }
    
    // Accept button handler
    acceptBtn.addEventListener('click', function() {
      localStorage.setItem('cookieConsent', 'accepted');
      banner.style.display = 'none';
      console.log('Cookies aceptadas');
    });
    
    // Reject button handler
    rejectBtn.addEventListener('click', function() {
      localStorage.setItem('cookieConsent', 'rejected');
      banner.style.display = 'none';
      console.log('Cookies rechazadas');
    });
  })();
</script>

