---
// Cookie Consent Banner Component
// This component handles cookie consent (analytics to be added later)
---
<div 
  id="cookie-consent-banner"
  class="fixed bottom-6 left-1/2 -translate-x-1/2 w-[95%] max-w-5xl 
  bg-white border border-slate-200 
  shadow-[0_20px_60px_rgba(15,23,42,0.08)] 
  rounded-2xl p-6 z-9999
  opacity-0 translate-y-10 
  transition-all duration-500"
  role="dialog"
  aria-labelledby="cookie-title"
  aria-describedby="cookie-description"
>

  <div class="flex flex-col md:flex-row gap-6 items-center justify-between">

    <!-- Texto -->
    <div class="flex items-start gap-4 flex-1">
      <div>
        <h3 id="cookie-title" class="text-lg font-semibold text-slate-900 mb-1">
          Política de Cookies
        </h3>

        <p id="cookie-description" class="text-sm text-slate-600 leading-relaxed">
          Utilizamos cookies para optimizar tu experiencia y garantizar el correcto funcionamiento del sitio.
          Puedes consultar nuestra 
          <a href="/legales/politica-privacidad" 
             class="text-teal-600 font-medium hover:underline">
            Política de Privacidad
          </a>.
        </p>
      </div>
    </div>

    <!-- Botones -->
    <div class="flex gap-3 shrink-0">
      <button 
        id="cookie-reject"
        class="px-5 py-2 rounded-full border border-slate-300 
        text-slate-700 text-sm font-medium 
        hover:bg-slate-100 transition"
      >
        Rechazar
      </button>

      <button 
        id="cookie-accept"
        class="px-6 py-2 rounded-full bg-teal-600 
        text-white text-sm font-semibold 
        shadow-md hover:bg-teal-700 
        hover:shadow-lg transition-all duration-300"
      >
        Aceptar
      </button>
    </div>

  </div>
</div>
<script is:inline>
(function() {
  const banner = document.getElementById('cookie-consent-banner');
  const acceptBtn = document.getElementById('cookie-accept');
  const rejectBtn = document.getElementById('cookie-reject');

  if (!banner || !acceptBtn || !rejectBtn) return;

  const COOKIE_KEY = 'osono_cookie_consent';
  const COOKIE_VERSION = '1.0';

  function showBanner() {
    setTimeout(() => {
      banner.classList.remove('opacity-0', 'translate-y-10');
      banner.classList.add('opacity-100', 'translate-y-0');
    }, 800);
  }

  function hideBanner() {
    banner.classList.add('opacity-0', 'translate-y-10');
    setTimeout(() => {
      banner.style.display = 'none';
    }, 400);
  }

  function checkConsent() {
    const saved = JSON.parse(localStorage.getItem(COOKIE_KEY));
    if (!saved || saved.version !== COOKIE_VERSION) {
      banner.style.display = 'block';
      showBanner();
    }
  }

  function saveConsent(status) {
    localStorage.setItem(COOKIE_KEY, JSON.stringify({
      status,
      version: COOKIE_VERSION,
      timestamp: new Date().toISOString()
    }));
    hideBanner();
  }

  acceptBtn.addEventListener('click', () => saveConsent('accepted'));
  rejectBtn.addEventListener('click', () => saveConsent('rejected'));

  checkConsent();
})();
</script>