---
import { company } from "../data/company";
import FooterLogo from "./footer/FooterLogo.astro";
import FooterServices from "./footer/FooterServices.astro";
import FooterContact from "./footer/FooterContact.astro";
import FooterSocial from "./footer/FooterSocial.astro";


interface Props {
  logoSrc?: string;
  logoAlt?: string;
  description?: string;
  ServicesItems?: { label: string; href: string }[];
  address?: { street: string; city: string; colony?: string };
  phone?: string;
  email?: string;
  socialLinks?: { icon: string; url: string }[];
  privacyUrl?: string;
  termsUrl?: string;
  avisoLegalUrl?: string;
}

const {
  logoSrc = "/img/head/ozono.png",
  logoAlt = "Osono Clinic Logo",
  description = company.description,
  ServicesItems = [
    { label: "Autohemoterapia Mayor", href: "#servicios" },
    { label: "Tratamiento de Columna", href: "#servicios" },
    { label: "Pie Diabético", href: "#servicios" },
    { label: "Bienestar Inmunológico", href: "#servicios" },
    { label: "Terapia de Ozonoterapia", href: "#servicios" },
    { label: "Terapia de Células Madre", href: "#servicios" },
  ],
  address = company.address,
  phone = company.contact?.phone,
  email = company.contact?.email,
  socialLinks = [
    { icon: "fa-facebook-f", url: company.social?.facebook || "#" },
    { icon: "fa-instagram", url: company.social?.instagram || "#" },
    { icon: "fa-whatsapp", url: company.contact?.whatsapp || "#" },
    { icon: "fa-tiktok", url: company.social?.tiktok || "#" },
    { icon: "fa-linkedin-in", url: company.social?.linkedin || "#" },
  ],
  privacyUrl = "/legales/politica-privacidad",
  termsUrl = "/legales/terminos-condiciones",
  avisoLegalUrl = "/legales/aviso-legal",
} = Astro.props;
---

<footer class="bg-slate-900 text-slate-400 border-t border-slate-800 relative overflow-hidden">
  <div class="absolute top-0 left-0 w-full h-px bg-linear-to-r from-transparent via-teal-500/30 to-transparent"></div>

  <div class="max-w-350 mx-auto px-6 py-12 md:py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-12">
      
      <div data-aos="fade-up" data-aos-delay="100">
        <FooterLogo 
          logoSrc={logoSrc} 
          logoAlt={logoAlt} 
          title="Ozonoterapia Médica" 
          description={description} 
        />
      </div>

      <div data-aos="fade-up" data-aos-delay="200">
        <FooterServices title="Servicios" servicesItems={ServicesItems} />
      </div>

      <div data-aos="fade-up" data-aos-delay="300">
        <FooterContact 
          address={`${address.street}<br/>${address.colony}, ${address.city}`} 
          phone={phone} 
          email={email} 
        />
      </div>

      <div data-aos="fade-up" data-aos-delay="400">
        <FooterSocial 
          socialLinks={socialLinks} 
          whatsappUrl={company.contact?.linkWhatsapp} 
        />
      </div>

    </div>
  </div>

  <div class="border-t border-slate-800/50" data-aos="fade-in" data-aos-duration="1500" data-aos-offset="0">
    <div class="max-w-350 mx-auto px-6 py-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-6 text-center md:text-left">
       <div class="flex flex-col md:flex-row items-center gap-4 md:gap-8 text-center md:text-left">
          <p class="text-xs md:text-sm font-medium text-slate-300">
            &copy; {new Date().getFullYear()} <span class="text-white">Osono Clinic</span>
          </p>
          
          <span class="hidden md:block w-px h-3 bg-slate-700"></span>
          
          <p class="text-[10px] uppercase tracking-[0.2em] text-slate-500">
            Diseñado y Desarrollado por Jhon QP
          </p>
        </div>

        <nav class="flex flex-wrap justify-center gap-6 text-[11px] uppercase tracking-widest font-bold">
          <a href={privacyUrl} class="hover:text-teal-500 transition-colors">Privacidad</a>
          <a href={termsUrl} class="hover:text-teal-500 transition-colors">Términos</a>
          <a href={avisoLegalUrl} class="hover:text-teal-500 transition-colors">Aviso Legal</a>
        </nav>
      </div>
      
      <p class="mt-8 text-[10px] leading-relaxed text-slate-600 text-center max-w-3xl mx-auto italic border-t border-slate-800/30 pt-4">
        Descargo: La ozonoterapia es un tratamiento complementario. Consulte siempre a su médico de cabecera en {address.city}. Los resultados pueden variar según cada paciente.
      </p>
    </div>
  </div>

  </footer>