---
// Header component for Osono Clinic
---

<header
  id="main-header"
  class="fixed top-0 left-0 w-full z-50 transition-all duration-500 bg-slate-900/90 backdrop-transparent"
>
  <div
    class="max-w-7xl mx-auto px-6 h-full flex justify-between items-center transition-all duration-500"
  >
    <!-- Logo -->
    <a href="/" class="flex items-center gap-3 group cursor-pointer">
      <img
        src="/img/head/logo.png"
        alt="Osono Clinic Logo"
        class="logo-img h-16 w-auto transition-all duration-500"
      />
    </a>

    <!-- Desktop Navigation (Modern Style) -->
    <nav
      class="hidden md:flex lg:flex items-center gap-6 lg:gap-10 nav-container text-base lg:text-lg font-semibold transition-all duration-500"
    >
      <a href="#ozonoterapia" class="nav-link relative group">
        Ozonoterapia
        <span
          class="absolute -bottom-1 left-0 w-0 h-0.5 bg-teal-500 transition-all duration-300 group-hover:w-full"
        ></span>
      </a>
      <a href="#servicios" class="nav-link relative group">
        Servicios
        <span
          class="absolute -bottom-1 left-0 w-0 h-0.5 bg-teal-500 transition-all duration-300 group-hover:w-full"
        ></span>
      </a>
      <a href="#planes" class="nav-link relative group">
        Planes
        <span
          class="absolute -bottom-1 left-0 w-0 h-0.5 bg-teal-500 transition-all duration-300 group-hover:w-full"
        ></span>
      </a>
      <a href="#nosotros" class="nav-link relative group">
        Nosotros
        <span
          class="absolute -bottom-1 left-0 w-0 h-0.5 bg-teal-500 transition-all duration-300 group-hover:w-full"
        ></span>
      </a>
      <a href="#faq" class="nav-link relative group">
        FAQ
        <span
          class="absolute -bottom-1 left-0 w-0 h-0.5 bg-teal-500 transition-all duration-300 group-hover:w-full"
        ></span>
      </a>

      <!-- CTA Button (Call to Action) -->
      <a
        href="#contacto"
        class="hidden md:flex items-center justify-center bg-[#338B85] text-white px-6 py-2.5 rounded-full hover:bg-teal-700 transition-all duration-300 shadow-md hover:shadow-xl hover:scale-105"
      >
        Contacto
      </a>
    </nav>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden lg:hidden xl:hidden p-3 rounded-lg text-white hover:bg-white/10 transition-colors duration-300 hamburger-btn"
        aria-label="Abrir menú"
        aria-expanded="false"
      >
        <span class="hamburger-icon">
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
          <span class="hamburger-line"></span>
        </span>
      </button>

  </div>
</header>

<!-- Mobile Menu Overlay (Backdrop) -->
<div
  id="mobile-menu-overlay"
  class="fixed inset-0 z-40 bg-black/20 backdrop-blur-sm transition-opacity duration-500 opacity-0 pointer-events-none"
  aria-hidden="true"
>
</div>

<!-- Mobile Menu (Off-canvas) -->
<div
  id="mobile-menu"
  class="fixed top-0 right-0 h-full w-[85%] max-w-sm z-50 transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.77,0,0.175,1)] bg-white shadow-2xl"
  aria-hidden="true"
>
  <div class="flex flex-col h-full">
    <!-- Header del menú móvil -->
    <div class="flex items-center justify-between p-6 border-b border-gray-100">
      <span class="text-xl font-bold text-gray-800">Menú</span>
      <button
        id="close-menu-btn"
        class="p-2 rounded-full hover:bg-gray-100 transition-colors"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          class="h-6 w-6 text-gray-600"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M6 18L18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>

    <!-- Menu Items -->
    <div class="flex-1 overflow-y-auto p-6">
      <div class="flex flex-col gap-6">
        <a href="#ozonoterapia"
          class="mobile-nav-link text-2xl font-bold text-gray-800 hover:text-teal-600 transition-colors">
          Ozonoterapia
        </a>
        <a href="#servicios"
          class="mobile-nav-link text-2xl font-bold text-gray-800 hover:text-teal-600 transition-colors">
          Servicios
        </a>
        <a href="#planes"
          class="mobile-nav-link text-2xl font-bold text-gray-800 hover:text-teal-600 transition-colors">
          Planes
        </a>
        <a href="#nosotros"  class="mobile-nav-link text-2xl font-bold text-gray-800 hover:text-teal-600 transition-colors">
          Nosotros
        </a>
      </div>

      <!-- CTA en móvil -->
      <div class="mt-8 pt-6 border-t border-gray-100">
        <a
          href="#contacto"
          class="block w-full text-center py-4 bg-[#338B85] text-white font-bold rounded-xl hover:bg-teal-700 transition-colors shadow-lg shadow-teal-500/20"
        >
          Contacto
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  // Mobile Menu Functionality
  (function () {
    const menuBtn = document.getElementById("mobile-menu-btn");
    const closeMenuBtn = document.getElementById("close-menu-btn");
    const mobileMenu = document.getElementById("mobile-menu");
    const mobileOverlay = document.getElementById("mobile-menu-overlay");
    const header = document.getElementById("main-header");

    if (!menuBtn || !closeMenuBtn || !mobileMenu || !mobileOverlay || !header) return;

    const _menuBtn = menuBtn;
    const _mobileMenu = mobileMenu;
    const _header = header;
    const _mobileOverlay = mobileOverlay;

    const mobileNavLinks = document.querySelectorAll(".mobile-nav-link");

    let isMenuOpen = false;

    function toggleMenu() {
      isMenuOpen = !isMenuOpen;

      if (isMenuOpen) {
        // Abrir menú
        _mobileMenu.classList.remove("translate-x-full");
        _mobileMenu.classList.add("open");
        _mobileOverlay.classList.remove("opacity-0", "pointer-events-none");
        _mobileOverlay.classList.add("opacity-100", "pointer-events-auto");
        _menuBtn.setAttribute("aria-expanded", "true");
        document.body.style.overflow = "hidden";
      } else {
        // Cerrar menú
        _mobileMenu.classList.add("translate-x-full");
        _mobileMenu.classList.remove("open");
        _mobileOverlay.classList.add("opacity-0", "pointer-events-none");
        _mobileOverlay.classList.remove("opacity-100", "pointer-events-auto");
        _menuBtn.setAttribute("aria-expanded", "false");
        document.body.style.overflow = "";
      }
    }

    _menuBtn.addEventListener("click", toggleMenu);
    closeMenuBtn.addEventListener("click", toggleMenu);
    _mobileOverlay.addEventListener("click", toggleMenu);

    // Close menu when clicking nav links
    mobileNavLinks.forEach(function (link) {
      link.addEventListener("click", function () {
        if (isMenuOpen) toggleMenu();
      });
    });

    // Close menu on escape key
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && isMenuOpen) {
        toggleMenu();
      }
    });
  })();

  // Header Scroll Effect
  (function () {
    const header = document.getElementById("main-header");
    if (!header) return;

    const _header = header;

    function handleScroll() {
      if (window.scrollY > 80) {
        _header.classList.add("header-scrolled");
      } else {
        _header.classList.remove("header-scrolled");
      }
    }

    window.addEventListener("scroll", handleScroll, { passive: true });
    handleScroll();
  })();
</script>

<style>
  /* ===== HEADER SCROLL STYLES (ORIGINAL) ===== */

  #main-header {
    height: 5rem;
    transition: all 0.4s ease;
    background: transparent;
    border-bottom: 1px solid transparent;
  }

  @media (min-width: 768px) {
    #main-header {
      height: 8rem;
    }
  }

  /* ===== ESTADO SCROLLED (ORIGINAL) ===== */
  #main-header.header-scrolled {
    height: 4rem;
    background-color: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
  }

  @media (min-width: 768px) {
    #main-header.header-scrolled {
      height: 5.5rem;
    }
  }

  /* Logo */
  #main-header .logo-img {
    height: 2.5rem;
    transition: all 0.4s ease;
  }

  @media (min-width: 768px) {
    #main-header .logo-img {
      height: 4rem;
    }
  }

  #main-header.header-scrolled .logo-img {
    height: 2rem;
  }

  @media (min-width: 768px) {
    #main-header.header-scrolled .logo-img {
      height: 2.5rem;
    }
  }

  /* ===== NAV LINKS (MODERN STYLE) ===== */
  .nav-link {
    color: #ffffff;
    position: relative;
    transition: color 0.3s ease;
  }

  #main-header.header-scrolled .nav-link {
    color: #0f172a; /* Color oscuro al hacer scroll */
  }

  /* ===== MOBILE MENU (OFF-CANVAS) STYLES ===== */

  /* Animación de entrada de enlaces */
  .mobile-nav-link {
    opacity: 0;
    transform: translateX(20px);
    transition:
      opacity 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      transform 0.5s cubic-bezier(0.4, 0, 0.2, 1),
      color 0.3s ease;
  }

  #mobile-menu.open .mobile-nav-link {
    opacity: 1;
    transform: translateX(0);
  }

  #mobile-menu.open .mobile-nav-link:nth-child(1) {
    transition-delay: 0.1s;
  }
  #mobile-menu.open .mobile-nav-link:nth-child(2) {
    transition-delay: 0.2s;
  }
  #mobile-menu.open .mobile-nav-link:nth-child(3) {
    transition-delay: 0.3s;
  }
  #mobile-menu.open .mobile-nav-link:nth-child(4) {
    transition-delay: 0.4s;
  }

  /* Hamburger Styles */
  .hamburger-btn {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .hamburger-icon {
    width: 22px;
    height: 16px;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .hamburger-line {
    width: 100%;
    height: 2px;
    background-color: currentColor;
    border-radius: 2px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Hamburger animation when menu is open */
  #mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    background-color: #2dd4bf;
  }

  #mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(2) {
    opacity: 0;
    transform: scaleX(0);
  }

  #mobile-menu-btn[aria-expanded="true"] .hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
    background-color: #2dd4bf;
  }

/* ===== RESPONSIVE FIXES ===== */
  @media (min-width: 1024px) {
    #mobile-menu-btn {
      display: none !important;
    }

    #mobile-menu {
      display: none !important;
    }

    #mobile-menu-overlay {
      display: none !important;
    }
  }

  /* Mobile menu button color on scroll */
  #main-header .hamburger-btn {
    color: #ffffff;
    transition: color 0.3s ease;
  }

  #main-header.header-scrolled .hamburger-btn {
    color: #334155;
  }
</style>
