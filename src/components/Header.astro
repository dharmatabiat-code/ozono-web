---
// Header.astro - Estructura Dharma con Estilo Osono
import { company } from "../data/company";
import NavDesktop from "./header/NavDesktop.astro";
import NavMobile from "./header/NavMobile.astro";

export interface Props {
  navItems?: { label: string; href: string }[];
  socialLinks?: { icon: string; url: string }[];
}

const {
  navItems = [
    { label: "Inicio", href: "#inicio" },         
    { label: "Acerca", href: "#nosotros" },     
    { label: "Ozonoterapia", href: "#ozonoterapia" },   
    { label: "Servicios", href: "#servicios" },  
    { label: "Direccion Medica", href: "#direccion-medica" },  
  ],
  
  socialLinks = [
    { icon: "facebook-f", url: company.social.facebook },
    { icon: "instagram", url: company.social.instagram },
    { icon: "tiktok", url: company.social.tiktok },
    { icon: "whatsapp", url: company.contact.linkWhatsapp },
  ],
} = Astro.props;

const navItemsMobile = [...navItems, {label: "Contacto", href: "#contacto" }];
---

<header
  id="main-header"
  class="fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent p-6 text-white"
>
  <div
    id="header-border"
    class="absolute bottom-0 left-0 right-0 h-px bg-transparent transition-all duration-500"
  ></div>

  <div class="max-w-350 mx-auto  flex items-center justify-between transition-all duration-500" id="header-container">
    <div class="flex items-center">
      <a href="/" class="flex items-center group" aria-label="Ir a inicio">
        <img
          id="main-logo"
          src="/img/head/ozono.png"
          class="h-14 md:h-16 w-auto object-contain transition-all duration-500 group-hover:scale-105"
          alt="Logo OSONO"
        />
      </a>
    </div>

    <NavDesktop navItems={navItems} />

    <button
      id="mobile-menu-btn"
      class="lg:hidden p-2 focus:outline-none transition-colors duration-300"
      aria-label="Abrir menú"
      aria-expanded="false"
    >
      <div class="w-7 h-5 flex flex-col justify-between items-end group">
        <span class="w-full h-[1.5px] bg-current rounded-full transition-all"></span>
        <span class="w-2/3 h-[1.5px] bg-current rounded-full transition-all group-hover:w-full"></span>
        <span class="w-full h-[1.5px] bg-current rounded-full transition-all"></span>
      </div>
    </button>
  </div>
</header>

<NavMobile navItemsMobile={navItemsMobile} socialLinks={socialLinks} />

<script>
  import { initHeader } from "../scripts/header.ts";
  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>

<style is:global>
  /* 1. Referencia para Tailwind v4 (Asegúrate de que la ruta sea correcta) */
  @reference "../styles/global.css"; 

  /* 2. Estado Scrolled */
  .header-scrolled {
    @apply bg-white/95 backdrop-blur-md shadow-lg py-3;
    color: #0f172a !important; /* slate-900 */
  }
 
  .header-scrolled #main-logo {
    @apply h-12 md:h-14;
  }

  /* 3. Colores de Navegación en Scroll */
  .header-scrolled nav a:not(.btn-contacto) {
    @apply text-slate-900 hover:text-teal-600;
  }
</style>