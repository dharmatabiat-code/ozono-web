---
import "../styles/global.css";
import "../styles/index.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { seo } from "../data/seo";
import { company } from "../data/company";
import { faqs as faq } from "../data/faq"; 

interface Props {
  title?: string;
  description?: string;
  canonicalURL?: string;
}

const {
  title = seo.meta.title.default,
  description = seo.meta.description.default,
  canonicalURL = Astro.url.href,
} = Astro.props;

const siteUrl = seo.site.url;
const defaultImage = "/logos/logo-osono.png";

// --- SCHEMAS (JSON-LD) ---
const medicalClinicSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  "name": seo.schema.medicalClinic.name,
  "description": seo.schema.medicalClinic.description,
  "url": siteUrl,
  "logo": siteUrl + "/logos/icono.png",
  "image": siteUrl + "/img/clinica-fachada.jpg",
  "priceRange": seo.schema.medicalClinic.priceRange,
  "paymentAccepted": seo.schema.medicalClinic.paymentAccepted,
  "currenciesAccepted": seo.schema.medicalClinic.currenciesAccepted,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": company.address.street,
    "addressLocality": company.address.city,
    "addressRegion": company.address.state,
    "postalCode": company.address.zip,
    "addressCountry": "PE"
  },
  "telephone": company.contact.phone,
  "email": company.contact.email
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faq.map((f) => ({
    "@type": "Question",
    "name": f.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": f.answer
    }
  }))
};
---

<!doctype html>
<html lang={seo.site.language} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    <link rel="icon" type="image/png" href="/icon.png" />
    <link rel="apple-touch-icon" href="/icon.png" />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content={seo.meta.author} />
    <meta name="keywords" content={seo.meta.keywords.join(", ")} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={siteUrl + defaultImage} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <script type="application/ld+json" set:html={JSON.stringify(medicalClinicSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </head>

  <body class="bg-slate-50 text-slate-900 antialiased font-sans">


    <Header />
    <main>
      <slot />
    </main>
     <Footer />
    <script src="../js/contacto.js"></script>
  </body>
</html>

<style is:global>
  :root {
    --brand-teal: #338B85;
    --brand-gold: #D4A52A;
  }
  
  /* Scrollbar Estilizada */
  ::-webkit-scrollbar { width: 8px; }
  ::-webkit-scrollbar-track { background: #f1f5f9; }
  ::-webkit-scrollbar-thumb { 
    background: var(--brand-teal); 
    border-radius: 10px; 
  }
</style>